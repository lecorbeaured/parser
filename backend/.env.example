# ── AZURE DOCUMENT INTELLIGENCE ───────────────────────
# Get from: Azure Portal → Document Intelligence resource → Keys and Endpoint
AZURE_DOC_INTEL_ENDPOINT=https://YOUR_RESOURCE_NAME.cognitiveservices.azure.com/
AZURE_DOC_INTEL_KEY=your_document_intelligence_key_here

# ── AZURE AI VISION (for scanned/image reports) ───────
# Get from: Azure Portal → Computer Vision resource → Keys and Endpoint
AZURE_VISION_ENDPOINT=https://YOUR_RESOURCE_NAME.cognitiveservices.azure.com/
AZURE_VISION_KEY=your_vision_key_here

# ── OPENAI ─────────────────────────────────────────────
# Get from: platform.openai.com → API keys
OPENAI_API_KEY=sk-your_openai_key_here
OPENAI_MODEL=gpt-4o   # or gpt-4o-mini for lower cost

# ── SERVER ─────────────────────────────────────────────
PORT=3000
NODE_ENV=development

# ── CORS ORIGIN ────────────────────────────────────────
# Your frontend domain (no trailing slash)
ALLOWED_ORIGIN=https://yourdomain.com

# ── RESEND (email delivery) ────────────────────────────
# Sign up at resend.com — free tier: 3,000 emails/month
RESEND_API_KEY=re_your_api_key_here
FROM_EMAIL=reports@yourdomain.com
FROM_NAME=PARSEUR 10X

# ── STRIPE ─────────────────────────────────────────────
# Create a $9/month product at dashboard.stripe.com → Payment Links
STRIPE_PAYMENT_LINK=https://buy.stripe.com/your_link_here

# ── CONTACT FORM ───────────────────────────────────────
# Where contact form submissions get forwarded
CONTACT_EMAIL=your@email.com
